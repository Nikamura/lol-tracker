{
  "name": "lol-tracker",
  "version": "0.1.0",
  "description": "Track LoL games played by a configured list of friends. Stores match history in SQLite for later analysis.",
  "type": "module",
  "bin": {
    "lol-tracker": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:web": "concurrently -k -n web,css -c blue,magenta \"tsx watch src/web/main.ts\" \"pnpm run web:css --watch\"",
    "web": "tsx src/web/main.ts",
    "web:css": "tailwindcss -i src/web/styles/app.css -o public/app.css",
    "watch": "tsc -p tsconfig.json --noEmit --watch",
    "build": "tsc -p tsconfig.json && pnpm run web:css --minify",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "node -e \"const fs=require('fs'); for (const f of ['./data/lol-tracker.db','./data/lol-tracker.db-shm','./data/lol-tracker.db-wal']) fs.rmSync(f, {force:true}); console.log('reset ok');\""
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.5.0",
    "citty": "^0.1.6",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.19",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
